generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum TransactionType {
  PIX_IN
  PIX_OUT
  CC_IN
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  status    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  transactions Transaction[]
  
  @@map("ag_pay_users")
}

model Setting {
  id                    Int      @id @default(autoincrement())
  active_acquirer       String   @default("pagarme")
  pix_fee_percent       Decimal  @default(1.00) @db.Decimal(5, 2)
  pix_fee_fixed         Decimal  @default(0.00) @db.Decimal(10, 2)
  cc_fee_percent        Decimal  @default(3.99) @db.Decimal(5, 2)
  cc_installments_fee   Decimal  @default(1.50) @db.Decimal(5, 2)
  receipt_deadline_days Int      @default(1)
  acquirer_credentials  String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("ag_pay_settings")
}

model Transaction {
  id                      Int               @id @default(autoincrement())
  agpay_user_id           Int
  type                    TransactionType
  amount                  Decimal           @db.Decimal(10, 2)
  net_amount              Decimal           @db.Decimal(10, 2)
  status                  TransactionStatus @default(PENDING)
  reference_id            String?           @db.VarChar(255)
  acquirer_transaction_id String?           @db.VarChar(255)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  user User @relation(fields: [agpay_user_id], references: [id])

  @@map("ag_pay_transactions")
}
